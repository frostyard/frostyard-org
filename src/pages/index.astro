---
import Site from "../layouts/Site.astro";
import extensionCatalog from "../data/extensions.json";
const heroScenes = ["moonlit-summit", "alpine-morning", "frozen-reflection", "blueprint"];
const images = [
  { name: "snow", type: "Desktop", title: "A GNOME workstation that stays composed.", body: "A daily desktop built on Debian Trixie with a current backports kernel, atomic OS updates, and room for real work.", tags: ["GNOME", "Backports kernel", "Atomic updates"] },
  { name: "snowfield", type: "Surface", title: "Snow, tuned for Surface hardware.", body: "The Snow desktop with linux-surface and the hardware support that makes a tablet or laptop feel like a first-class machine.", tags: ["GNOME", "linux-surface", "Touch-ready"] },
  { name: "cayo", type: "Server", title: "A quiet base for services and containers.", body: "A headless image for servers, labs, and small infrastructure. Podman is ready; the host stays deliberately uninteresting.", tags: ["Headless", "Containers", "Virtualization"] },
];

type Extension = typeof extensionCatalog.extensions[number];
const groupDefinitions: Array<[string, string[]]> = [
  ["Workstation", ["1password", "bitwarden", "claude-desktop", "edge", "vscode"]],
  ["Development", ["dev", "debdev", "nix", "podman", "docker"]],
  ["Infrastructure", ["tailscale", "azurevpn", "incus", "coder", "code-server", "lemonade"]],
];
const extensionGroups: Array<{ name: string; extensions: Extension[] }> = groupDefinitions.map(([name, members]) => ({
  name,
  extensions: members.flatMap(member => {
    const extension = extensionCatalog.extensions.find(candidate => candidate.name === member);
    return extension ? [extension] : [];
  }),
}));
const groupedExtensionNames = new Set(extensionGroups.flatMap(group => group.extensions.map(extension => extension.name)));
const otherExtensions = extensionCatalog.extensions.filter(extension => !groupedExtensionNames.has(extension.name));
if (otherExtensions.length) extensionGroups.push({ name: "Also published", extensions: otherExtensions });
---

<Site title="Frostyard | Composed operating systems" description="Frostyard builds composed, updateable operating system images with snosi.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow"><span></span> Debian · mkosi · bootc or A/B root</p>
      <h1>Keep the system<br /><em>boring.</em> Make the work interesting.</h1>
      <p class="lede">Frostyard images are atomic, updateable operating systems for desktops and servers. A known-good base stays put; your tools arrive as deliberate layers.</p>
      <div class="hero-actions"><a class="button primary" href="#images">Explore images <span>↓</span></a><a class="button ghost" href="https://github.com/frostyard/snosi">Read the build <span>↗</span></a></div>
    </div>
    <div class="altitude" aria-hidden="true">
      <svg class="rise" viewBox="0 0 2 440" preserveAspectRatio="none"><path d="M 1 30 V 330" /></svg>
      <div class="layer float l1"></div>
      <div class="layer float l2"></div>
      <div class="layer float l3"></div>
      <div class="layer l4"></div>
      <div class="layer l5"></div>
      <div class="alt-label lb1">USER SPACE<i></i><small>brew · flatpak · nix</small></div>
      <div class="alt-label lb2">CONTAINERS<i></i><small>podman · distrobox · incus</small></div>
      <div class="alt-label lb3">SYSEXT LAYER<i></i><small>versioned · removable</small></div>
      <div class="alt-label lb4">BASE IMAGE<i></i><small>known-good · stays put</small></div>
    </div>
  </section>

  <section class="principles" aria-label="Principles">
    <article><span class="number">01</span><h2>Atomic by default</h2><p>Update the whole operating system as a coherent image. Reboot into the new deployment; keep the previous one available.</p></article>
    <article><span class="number">02</span><h2>Mutable where it counts</h2><p>Your data, configuration, containers, and projects live in persistent writable storage. The operating system does not get in their way.</p></article>
    <article><span class="number">03</span><h2>Tools without drift</h2><p>Add capabilities as system extensions, containers, or user-space package environments instead of turning the base into a snowball.</p></article>
  </section>

  <section class="images section" id="images">
    <div class="section-heading"><p class="eyebrow"><span></span> Three base images</p><h2>Choose the terrain.<br />The foundation is shared.</h2><p>Each image starts from the same reproducible Debian base and takes a clear role from there.</p></div>
    <div class="composition-map" aria-label="Base image composition: Base feeds Cayo and Snow. Snow feeds Snowfield. System extensions add optional capabilities to Cayo, Snow, and Snowfield.">
      <div class="map-copy"><span>How the images relate</span><strong>One shared base. One desktop variation. Optional layers for every image.</strong></div>
      <svg viewBox="0 0 960 320" role="img" aria-labelledby="composition-title composition-description">
        <title id="composition-title">Frostyard image composition</title><desc id="composition-description">The shared base image branches to the Cayo server and Snow desktop. Snow leads to the Snowfield Surface desktop. System extensions add optional capabilities to each image.</desc>
        <defs><marker id="arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="6" markerHeight="6" orient="auto-start-reverse"><path d="M 0 0 L 8 4 L 0 8 z" /></marker></defs>
        <path class="main-line energy-line" d="M 205 86 H 350" marker-end="url(#arrow)" />
        <path class="main-line energy-line" d="M 205 106 H 282 V 190 H 350" marker-end="url(#arrow)" />
        <path class="main-line energy-line" d="M 530 190 H 620" marker-end="url(#arrow)" />
        <path class="layer-line" d="M 430 264 V 130 M 450 264 V 234 M 700 264 V 234" />
        <a href="/base" class="map-node base-node"><rect x="35" y="55" width="170" height="82" rx="3" /><text x="53" y="82" class="node-kicker">SHARED FOUNDATION</text><text x="53" y="112" class="node-name">shared base</text><text x="53" y="129" class="node-detail">system · boot · tools</text></a>
        <a href="/cayo" class="map-node"><rect x="350" y="42" width="180" height="88" rx="3" /><text x="368" y="70" class="node-kicker">SERVER IMAGE</text><text x="368" y="101" class="node-name">cayo</text><text x="368" y="119" class="node-detail">headless · containers</text></a>
        <a href="/snow" class="map-node"><rect x="350" y="146" width="180" height="88" rx="3" /><text x="368" y="174" class="node-kicker">DESKTOP IMAGE</text><text x="368" y="205" class="node-name">snow</text><text x="368" y="223" class="node-detail">GNOME · backports kernel</text></a>
        <a href="/snowfield" class="map-node snowfield-node"><rect x="620" y="146" width="210" height="88" rx="3" /><text x="638" y="174" class="node-kicker">SURFACE DESKTOP</text><text x="638" y="205" class="node-name">snowfield</text><text x="638" y="223" class="node-detail">Snow · linux-surface kernel</text></a>
        <a href="#extensions" class="extension-node"><rect x="285" y="264" width="620" height="42" rx="3" /><text x="307" y="291" class="extension-label">SYSEXT LAYER</text><text x="450" y="291" class="extension-detail">optional capabilities for any image · Incus · Docker · Podman · dev tools · apps</text></a>
      </svg>
    </div>
    <div class="image-grid">
      {images.map((image, index) => <article class="image-card" data-index={index}>
        <div class="card-top"><span>{image.type}</span><b>0{index + 1}</b></div>
        <div class="art" aria-hidden="true"><img src={`/assets/hero/${heroScenes[index % heroScenes.length]}.png`} alt="" loading="lazy" /><div class="art-shade"></div></div>
        <h3><a href={`/${image.name}`}>{image.name}</a></h3><h4>{image.title}</h4><p>{image.body}</p>
        <div class="tags">{image.tags.map(tag => <span class="tag">{tag}</span>)}</div>
      </article>)}
    </div>
  </section>

  <section class="extensions section" id="extensions">
    <div class="section-heading compact"><p class="eyebrow"><span></span> System extensions</p><h2>More capability.<br />No base-image sprawl.</h2><p>Sysexts are versioned, removable overlays for the parts of your system that deserve their own lifecycle.</p></div>
    <div class="extension-area">
      <div class="extension-total"><strong>{extensionCatalog.extensions.length}</strong><p>published extensions<br />in the live catalog</p><a href={extensionCatalog.source}>View repository index ↗</a><div class="ice-line"></div></div>
      <div class="extension-groups">{extensionGroups.map(group => <article><p>{group.name}</p><div>{group.extensions.map(extension => <span class="tag" title={extension.name}>{extension.label}{extension.version && <small>v{extension.version}</small>}</span>)}</div></article>)}</div>
    </div>
  </section>

  <section class="workflow section" id="workflow">
    <div class="workflow-panel"><div><p class="eyebrow"><span></span> The practical model</p><h2>Install software<br />at the right altitude.</h2><p>Immutability is not a prohibition. It is a boundary that makes each choice easier to reverse and reason about.</p></div><div class="lanes"><article><b>01</b><div><h3>System extension</h3><p>For a tool that belongs close to the OS: VPNs, IDEs, container runtimes, and services.</p></div></article><article><b>02</b><div><h3>Container or Distrobox</h3><p>For development stacks and workloads that should bring their own userspace.</p></div></article><article><b>03</b><div><h3>User-space environment</h3><p>For personal tooling with Nix, Homebrew, Flatpak, or a project-local runtime.</p></div></article></div></div>
  </section>

  <section class="build-callout"><div><p class="eyebrow"><span></span> No magic, just composition</p><h2>Built in the open<br />with <code>mkosi</code>.</h2></div><p>Cayo, Snow, and Snowfield share one definition, then branch only where purpose demands: packages, kernel, and configuration.</p><a class="button primary" href="https://github.com/frostyard/snosi">Inspect snosi <span>↗</span></a></section>
</Site>

<style>
  .hero{min-height:600px;display:grid;grid-template-columns:1.1fr .9fr;align-items:center;position:relative;overflow:hidden}
  .hero-copy{padding:7rem 0}
  .hero h1{font-size:var(--text-display-size);line-height:var(--text-display-lh);letter-spacing:var(--text-display-ls);font-weight:var(--text-display-weight);margin:0;max-width:720px}
  .hero h1 em{font-family:var(--font-serif-accent);font-weight:400;color:var(--ice)}
  .lede{font-size:var(--text-lede-size);color:var(--text-muted);max-width:565px;margin:2rem 0 2.4rem}
  .hero-actions{display:flex;gap:.8rem}

  /* Altitude stack — deliberate layers above a known-good base */
  .altitude{height:440px;position:relative}
  .altitude .rise{position:absolute;left:42%;top:0;height:100%;width:2px;overflow:visible}
  .altitude .rise path{fill:none;stroke:#8ee3ff;stroke-width:1.4;stroke-dasharray:3 8;filter:drop-shadow(0 0 2px #78dfff);animation:rise 1.8s linear infinite}
  .layer{position:absolute;left:42%;width:200px;height:200px;transform:translateX(-50%) rotateX(58deg) rotateZ(45deg)}
  .float{animation:bob 5s ease-in-out infinite alternate}
  .l1{top:28px;background:rgba(174,233,255,.06);border:1px solid #8fdffb4d;animation-delay:-1s}
  .l2{top:104px;background:rgba(174,233,255,.09);border:1px solid #8fdffb66;animation-delay:-2.6s}
  .l3{top:180px;background:#091c2d99;border:1px dashed #78d6f4;animation-delay:-4.2s}
  .l4{top:292px;background:#052033;border:1px solid #1c4a66}
  .l5{top:280px;background:linear-gradient(145deg,#1d91c8,#0a3454);border:1px solid #b1edff9e;box-shadow:0 0 50px #3cbdf444}
  .alt-label{position:absolute;right:0;text-align:right;font-family:var(--font-mono);font-size:.6rem;letter-spacing:.12em;color:#7fd9f8;white-space:nowrap}
  .alt-label small{display:block;color:#91b8cb;font-size:.58rem;letter-spacing:.04em;margin-top:.2rem}
  .alt-label i{display:inline-block;width:26px;height:1px;background:#6bcaf0;vertical-align:middle;margin-left:.5rem;opacity:.6}
  .lb1{top:66px}.lb2{top:142px}.lb3{top:218px}.lb4{top:324px;color:var(--ice)}
  @keyframes bob{from{transform:translateX(-50%) rotateX(58deg) rotateZ(45deg) translateZ(0)}to{transform:translateX(-50%) rotateX(58deg) rotateZ(45deg) translateZ(16px)}}
  @keyframes rise{to{stroke-dashoffset:-22}}

  .principles{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .principles article{padding:2.25rem 2rem 2.4rem 0}
  .principles article+article{padding-left:2rem;border-left:1px solid var(--line)}
  .number{color:var(--sky);font-family:var(--font-mono);font-size:var(--text-mono-size)}
  .principles h2{font-size:1.08rem;margin:.75rem 0}
  .principles p,.section-heading>p:not(.eyebrow),.build-callout>p{color:var(--text-dim);font-size:.91rem;margin:0}

  .section{padding:var(--section-pad) 0}
  .section-heading{max-width:670px}
  .section-heading h2,.build-callout h2{font-size:var(--text-h2-size);letter-spacing:var(--text-h2-ls);line-height:var(--text-h2-lh);margin:.25rem 0 1.25rem}
  .section-heading.compact h2{font-size:var(--text-h2-compact-size)}

  .image-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:3.3rem}
  .image-card{min-height:425px;border:1px solid var(--line);background:var(--gradient-card);padding:var(--card-pad);position:relative;overflow:hidden}
  .image-card[data-index="1"]{background:var(--gradient-card-alt)}
  .image-card[data-index="2"]{background:var(--gradient-card-deep)}
  .card-top{display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:.68rem;text-transform:uppercase;letter-spacing:.09em;color:#9bcbdf}
  .card-top b{font-weight:400;color:#6b93a8}
  .art{height:125px;position:relative;margin:1rem calc(-1 * var(--card-pad)) 1.3rem;overflow:hidden}
  .art img{position:absolute;inset:0;width:100%;height:220%;object-fit:cover;object-position:50% 58%;display:block}
  .art-shade{position:absolute;inset:0;background:linear-gradient(180deg,rgba(6,17,29,.25),transparent 40%,rgba(9,28,45,.55))}
  .image-card h3{font-size:2rem;letter-spacing:-.06em;margin:0}
  .image-card h4{font-size:1rem;margin:.5rem 0;color:#e7f8ff}
  .image-card p{font-size:.87rem;color:#b5cedb;margin:0}
  .tags{display:flex;gap:.35rem;flex-wrap:wrap;margin-top:1.4rem}

  .extensions{border-top:1px solid var(--line);display:grid;grid-template-columns:.85fr 1.15fr;gap:4rem}
  .extension-area{display:grid;grid-template-columns:.7fr 1.3fr;gap:2rem;align-items:center}
  .extension-total strong{font-size:7rem;letter-spacing:-.09em;line-height:.8;color:var(--ice)}
  .extension-total p{color:#a7c2d0;font-size:var(--text-caption-size);margin:1rem 0}
  .extension-total a{color:var(--link);font-size:var(--text-mono-size)}
  .extension-total a:hover{color:var(--link-hover)}
  .ice-line{height:1px;background:var(--gradient-ice-line);width:100%;margin-top:1.1rem}
  .extension-groups article{padding:1.1rem 0;border-bottom:1px solid var(--line)}
  .extension-groups article:first-child{border-top:1px solid var(--line)}
  .extension-groups p{font-size:.72rem;text-transform:uppercase;letter-spacing:.14em;color:#7cbddc;margin:.1rem 0 .75rem}
  .extension-groups div{display:flex;flex-wrap:wrap;gap:.35rem}

  .workflow{padding-top:1rem}
  .workflow-panel{background:var(--panel-bright);border:1px solid var(--line-strong);padding:var(--panel-pad);display:grid;grid-template-columns:1fr 1fr;gap:4rem;position:relative;overflow:hidden}
  .workflow-panel:after{content:"";position:absolute;width:400px;height:400px;border:1px solid #5dc2e333;border-radius:50%;right:-260px;bottom:-280px}
  .workflow-panel h2{font-size:var(--text-h2-compact-size);line-height:1;letter-spacing:var(--text-h2-ls);margin:.2rem 0 1.3rem}
  .workflow-panel>div>p:not(.eyebrow){color:#b7d3df;max-width:370px}
  .lanes article{display:flex;gap:1rem;padding:1.15rem 0;border-top:1px solid #92d8f43d;position:relative;z-index:1}
  .lanes b{font-family:var(--font-mono);font-size:.7rem;color:#62c7ef}
  .lanes h3{font-size:1rem;margin:0}
  .lanes p{font-size:var(--text-caption-size);color:#a9c7d5;margin:.3rem 0 0}

  .build-callout{margin:var(--section-pad) 0;display:grid;grid-template-columns:1fr .8fr auto;gap:3rem;align-items:end;border-bottom:1px solid var(--line);padding-bottom:3rem}
  .build-callout h2{margin-bottom:0}
  .build-callout code{color:#8ee3ff;font-size:.8em;font-family:var(--font-mono)}

  /* Composition map */
  .composition-map{background:var(--gradient-panel);border:1px solid var(--line);margin-top:3rem;overflow:hidden;padding:1.4rem 1.8rem 1.6rem}
  .map-copy{align-items:baseline;display:flex;gap:1rem;margin-bottom:.8rem}
  .map-copy span{color:#6bcaf0;font-size:.65rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase}
  .map-copy strong{font-size:1rem;font-weight:550;letter-spacing:-.02em}
  .composition-map svg{display:block;height:auto;width:100%}
  .main-line{fill:none;stroke:#8ee3ff;stroke-width:1.4}
  .energy-line{filter:drop-shadow(0 0 2px #78dfff);stroke-dasharray:3 8;animation:energy-flow 1.8s linear infinite}
  .layer-line{fill:none;stroke:#6bcaf0;stroke-dasharray:4 5;stroke-width:1.3}
  .map-node rect{fill:#103a55;stroke:#8fdffb;stroke-opacity:.55}
  .map-node:hover rect{fill:#185473;stroke-opacity:1}
  .snowfield-node rect{fill:#15516b}
  .node-kicker{fill:#7fd9f8;font-family:var(--font-mono);font-size:9px;letter-spacing:1.1px}
  .node-name{fill:#effaff;font-family:var(--font-sans);font-size:23px;font-weight:750;letter-spacing:-1px}
  .node-detail{fill:#91b8cb;font-family:var(--font-sans);font-size:10px}
  .extension-node rect{fill:#091c2d;stroke:#78d6f4;stroke-dasharray:4 4;stroke-opacity:.75}
  .extension-label{fill:var(--ice);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px}
  .extension-detail{fill:#90b9cc;font-family:var(--font-sans);font-size:11px}
  .composition-map marker path{fill:#8ee3ff}
  @keyframes energy-flow{to{stroke-dashoffset:-22}}

  @media(prefers-reduced-motion:reduce){.energy-line,.float,.altitude .rise path{animation:none}}
  @media(max-width:800px){
    .hero{grid-template-columns:1fr;min-height:auto}
    .hero-copy{padding:5rem 0 1rem}
    .hero h1{font-size:3.4rem}
    .altitude{height:350px;transform:scale(.78);transform-origin:top center}
    .principles,.extensions,.workflow-panel{grid-template-columns:1fr}
    .principles article,.principles article+article{padding:1.5rem 0;border-left:0;border-top:1px solid var(--line)}
    .principles article:first-child{border-top:0}
    .section{padding:var(--section-pad-mobile) 0}
    .image-grid{grid-template-columns:1fr}
    .image-card{min-height:365px}
    .extensions{gap:2.5rem}
    .extension-area{grid-template-columns:1fr}
    .workflow-panel{padding:2rem;gap:2rem}
    .build-callout{margin:var(--section-pad-mobile) 0;grid-template-columns:1fr;gap:1.5rem}
    .build-callout .button{width:max-content}
    .composition-map{margin-top:2rem;padding:1rem;overflow-x:auto}
    .map-copy{align-items:flex-start;flex-direction:column;gap:.3rem}
    .composition-map svg{min-width:680px}
  }
</style>
