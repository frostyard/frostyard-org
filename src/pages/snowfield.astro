---
import Site from "../layouts/Site.astro";
const facts = [["Surface-aware kernel", "linux-surface, headers, libwacom-surface, and iptsd tailor the system for Surface touch, pen, keyboard, and platform hardware."], ["Graphics and firmware", "A current Mesa stack and broad backports firmware coverage support the graphics, wireless, audio, and peripheral hardware a mobile machine relies on."], ["The full Snow desktop", "Snowfield retains the same GNOME, software-layering, and workstation experience as Snow. The difference is the hardware focus, not a reduced desktop."]];
---
<Site title="Snowfield | Frostyard" description="A Frostyard GNOME desktop tuned for Surface devices." active="images" footerLabel="Explore tools →" footerHref="/tools">
  <header class="hero"><p class="eyebrow"><i></i> Snowfield · Surface desktop</p><h1>Snow, shaped for<br /><em>the hardware in hand.</em></h1><p class="lede">Snowfield brings the Snow workstation to Surface devices with the linux-surface kernel and the supporting hardware stack already composed into the image.</p></header>
  <section class="signal"><span>SNOWFIELD</span><p>GNOME desktop · linux-surface · Touch and pen support</p></section>
  <section class="facts">{facts.map(([title, body], index) => <article><b>0{index + 1}</b><h2>{title}</h2><p>{body}</p></article>)}</section>
  <section class="bottom"><div><p class="eyebrow"><i></i> A focused variation</p><h2>One shared desktop.<br />A closer fit for Surface.</h2></div><p>Snowfield takes Snow’s desktop composition and changes the part that matters for Surface hardware: the kernel and its companion drivers, firmware, and input support.</p></section>
</Site>
<style>
  .hero{padding:7rem 0 5rem;max-width:900px}
  .hero h1{font-size:var(--text-display-size);line-height:var(--text-display-lh);letter-spacing:var(--text-display-ls);font-weight:var(--text-display-weight);margin:0}
  .hero h1 em{font-family:var(--font-serif-accent);font-weight:400;color:var(--ice)}
  .lede{font-size:var(--text-lede-size);color:var(--text-muted);max-width:620px;margin:2rem 0 0}
  .signal{background:linear-gradient(135deg,#16455d,#0a2033);border:1px solid var(--line);padding:2rem 2.3rem;display:flex;align-items:center;justify-content:space-between}
  .signal span{font-size:2.4rem;font-weight:800;letter-spacing:-.08em;color:var(--ice)}
  .signal p{font:var(--text-mono-size) var(--font-mono);color:#91cee7;margin:0}
  .facts{display:grid;grid-template-columns:repeat(3,1fr);margin-top:1rem;border-top:1px solid var(--line)}
  .facts article{padding:2.5rem 2rem 2.5rem 0;border-bottom:1px solid var(--line)}
  .facts article+article{padding-left:2rem;border-left:1px solid var(--line)}
  .facts b{font:400 .7rem var(--font-mono);color:var(--sky)}
  .facts h2{font-size:1.2rem;margin:.8rem 0}
  .facts p,.bottom>p{font-size:.9rem;color:var(--text-muted);margin:0}
  .bottom{margin:7rem 0 5rem;display:grid;grid-template-columns:1.2fr .8fr;gap:4rem;align-items:end}
  .bottom h2{font-size:clamp(2.3rem,3.8vw,4rem);line-height:1;letter-spacing:var(--text-h2-ls);margin:0}
  @media(max-width:800px){
    .hero{padding:5rem 0 4rem}
    .signal{display:block}
    .signal p{margin-top:.7rem}
    .facts,.bottom{grid-template-columns:1fr;gap:2rem}
    .facts article,.facts article+article{padding:1.8rem 0;border-left:0}
    .bottom{margin-top:5rem}
  }
</style>
