---
import Site from "../layouts/Site.astro";
const facts = [["Desktop first", "GNOME, GDM, PipeWire, Ghostty, Flatpak, printing, remote desktop, and practical accessibility support are part of the image."], ["Current hardware stack", "The Debian backports kernel, graphics stack, and broad firmware set keep a workstation current without turning it into a rolling release."], ["Work-friendly layers", "ChairLift, Homebrew support, Podman, Distrobox, and system extensions give development and desktop software a place to live."]];
---
<Site title="Snow | Frostyard" description="A composed GNOME workstation from Frostyard." active="images" footerLabel="Explore tools →" footerHref="/tools">
  <header class="hero"><p class="eyebrow"><i></i> Snow · GNOME workstation</p><h1>A desktop that<br /><em>holds its shape.</em></h1><p class="lede">Snow is the everyday Frostyard workstation: a GNOME desktop with an atomic operating system below it and practical places for the tools above it.</p></header>
  <section class="signal"><span>SNOW</span><p>GNOME desktop · Backports kernel · Atomic updates</p></section>
  <section class="facts">{facts.map(([title, body], index) => <article><b>0{index + 1}</b><h2>{title}</h2><p>{body}</p></article>)}</section>
  <section class="bottom"><div><p class="eyebrow"><i></i> For a daily machine</p><h2>Work on the surface.<br />Keep the system below calm.</h2></div><p>Use extensions for system-adjacent software, containers for development environments, and user-space package tools for everything personal. Snow keeps those choices separate without making them feel distant.</p></section>
</Site>
<style>
  .hero{padding:7rem 0 5rem;max-width:850px}
  .hero h1{font-size:var(--text-display-size);line-height:var(--text-display-lh);letter-spacing:var(--text-display-ls);font-weight:var(--text-display-weight);margin:0}
  .hero h1 em{font-family:var(--font-serif-accent);font-weight:400;color:var(--ice)}
  .lede{font-size:var(--text-lede-size);color:var(--text-muted);max-width:580px;margin:2rem 0 0}
  .signal{background:var(--gradient-signal);border:1px solid var(--line);padding:2rem 2.3rem;display:flex;align-items:center;justify-content:space-between}
  .signal span{font-size:2.7rem;font-weight:800;letter-spacing:-.08em;color:var(--ice)}
  .signal p{font:var(--text-mono-size) var(--font-mono);color:#91cee7;margin:0}
  .facts{display:grid;grid-template-columns:repeat(3,1fr);margin-top:1rem;border-top:1px solid var(--line)}
  .facts article{padding:2.5rem 2rem 2.5rem 0;border-bottom:1px solid var(--line)}
  .facts article+article{padding-left:2rem;border-left:1px solid var(--line)}
  .facts b{font:400 .7rem var(--font-mono);color:var(--sky)}
  .facts h2{font-size:1.2rem;margin:.8rem 0}
  .facts p,.bottom>p{font-size:.9rem;color:var(--text-muted);margin:0}
  .bottom{margin:7rem 0 5rem;display:grid;grid-template-columns:1.2fr .8fr;gap:4rem;align-items:end}
  .bottom h2{font-size:clamp(2.3rem,3.8vw,4rem);line-height:1;letter-spacing:var(--text-h2-ls);margin:0}
  @media(max-width:800px){
    .hero{padding:5rem 0 4rem}
    .signal{display:block}
    .signal p{margin-top:.7rem}
    .facts,.bottom{grid-template-columns:1fr;gap:2rem}
    .facts article,.facts article+article{padding:1.8rem 0;border-left:0}
    .bottom{margin-top:5rem}
  }
</style>
