---
interface Props { title: string; description: string; active?: string }
const { title, description, active } = Astro.props;
---
<html lang="en">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width" /><meta name="description" content={description} /><title>{title} | Frostyard</title></head>
  <body>
    <main>
      <nav aria-label="Primary navigation"><a class="brand" href="/"><span>✦</span> frostyard</a><div class="nav-links"><a href="/base" class:list={[active === "base" && "current"]}>Base</a><a href="/#images" class:list={[active === "images" && "current"]}>Images</a><a href="/why-atomic" class:list={[active === "atomic" && "current"]}>Why Atomic</a><a href="/tools">Tools</a></div><a class="source" href="https://github.com/frostyard/snosi">Source ↗</a></nav>
      <slot />
    </main>
    <footer><a class="brand" href="/"><span>✦</span> frostyard</a><p>Cold systems. Clear boundaries.</p><a href="/tools">Explore tools →</a></footer>
  </body>
</html>

<style>
  :root{--ink:#06111d;--panel:#0d263b;--line:rgba(162,222,255,.18);--ice:#aee9ff;--sky:#47b8ef;--mist:#b6d0df}*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at 78% 2%,#10416455,transparent 28rem),linear-gradient(180deg,#071a2a,#06111d 55%);color:#edf8ff;font-family:Inter,ui-sans-serif,system-ui,sans-serif;line-height:1.5}main,footer{max-width:1240px;margin:auto;padding-left:32px;padding-right:32px}nav{height:92px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line)}a{color:inherit;text-decoration:none}.brand{font-weight:720;letter-spacing:-.04em;font-size:1.25rem}.brand span{color:var(--ice);font-size:1.55rem;margin-right:.3rem}.nav-links{display:flex;gap:2rem;font-size:.87rem;color:#b7d0df}.nav-links a:hover,.nav-links .current{color:var(--ice)}.source{font-size:.8rem;border:1px solid var(--line);padding:.55rem .8rem;border-radius:100px;color:#d9f2ff}footer{padding-bottom:3rem;display:flex;justify-content:space-between;align-items:center;color:#7799ab;font-size:.8rem}footer p{margin:0}footer a:last-child{color:#a4d9ef}@media(max-width:720px){main,footer{padding-left:20px;padding-right:20px}nav{height:72px}.nav-links{display:none}.source{font-size:.7rem}footer{flex-wrap:wrap;gap:1rem}}
</style>
